//给定两个整数 𝑥,𝑦，构造一个整数 𝑛使得 𝑥⊕𝑛>𝑦⊕𝑛.
//比较两个数的大小，是从最高位往最低位看，第一次遇到某一位不同，该位的值决定了谁大谁小。
//把 𝑛取为：𝑥⊕𝑦的最高位（仅保留最高位 1，其余位 0）为什么？
//• 𝑥⊕𝑦中的 1 位，就是 𝑥和 𝑦不同的位。
//• 最高的那个不同位，就是第一次比较时决定大小关系的位，且必然是 𝑥为 0、𝑦为 1。
//• 对这个最高位取 1 作为 𝑛，就能翻转这一位，使 𝑥的变成 1，𝑦的变成 0，从而 𝑥⊕𝑛>𝑦⊕𝑛。
#include <stdio.h>
int main(){
    int t;
    scanf("%d",&t);
    while(t--){
        long long x,y;
        scanf("%lld%lld",&x,&y);
        long long diff=x^y;
        long long n=1LL<<31;
        while((n&diff)==0){
            n>>=1;
        }
        printf("%lld\n",n);
    }
    return 0;
}

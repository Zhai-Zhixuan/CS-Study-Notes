//求x的总因子数：如果 x = p₁^a₁ × p₂^a₂ × ... × pₙ^aₙ，那么 wt(x) = (a₁+1) × (a₂+1) × ... × (aₙ+1)
#include <stdio.h>
#define X 200005
int is_prime[X];
void sieve() {
    for (int i = 2; i < X; i++) {
        is_prime[i] = 1;
    }
    is_prime[0] =is_prime[1] = 0;
    for (int i = 2; i * i < X; i++) {
        if (is_prime[i]) {
            for (int j = i * i; j < X; j += i) {
                is_prime[j] = 0;
            }
        }
    }
}
int main() {
    int t;
    scanf("%d", &t);
    sieve();
    while (t--) {
        int x;
        scanf("%d", &x);
        int factors[100][2]; //factors[i][0]质因数，factors[i][1]指数
        int factor_cnt = 0;
        int temp = x;
        for (int i = 2; i * i <= temp; i++) {
            if(i*i>temp){
                break;
            }
            if(temp%i==0) {
                factors[factor_cnt][0] = i;
                factors[factor_cnt][1] = 0;
                while(temp % i == 0){
                    temp/=i;
                    factors[factor_cnt][1]++;
                }
                //printf("%d ",i);
                factor_cnt++;
            }
        }
        if (temp!=1){
            factors[factor_cnt][0]=temp;
            factors[factor_cnt][1]=1;
            factor_cnt++;
        }
        if(factor_cnt == 1){ //只有一个质因子，2*px(拆)>px+1(不拆),拆成全部质因子的权值和
            printf("%d\n",factors[0][1]*2);
        }
        else{ //多种质因数，sum(2*px)(拆)<times(px+1)(不拆),利用公式计算最大因子数即权值和
            int ans = 1;
            for(int i=0;i<factor_cnt;i++){
                ans *= (factors[i][1]+1);
            }
            printf("%d\n",ans);
        }
    }
    return 0;
}

#include<stdio.h>
int is_good(long long n,long long k){ //进制转换：n 在 k 进制下的每一位 = n % k，然后 n /= k
    while(n>0){
        if(n%k>1){
            return 0;
        }
        n/=k;
    }
    return 1;
}
int main(){
    long long n;
    scanf("%lld",&n);
    if(n==1){ //特殊情况
        printf("YES\n");
        printf("2 3");
    }
    long long k1=-1,k2=-1;
    for(long long i=2;i<1000000&&i<=n;i++){
        if(is_good(n,i)){
            if(k1==-1){
                k1=i;
            }
            else{
                k2=i;
                break;
            }
        }
    }
    if(k2==-1&&k1!=-1&&k1!=n&&n>2){ //特殊情况：k = n 时一定成立（n 在 n 进制下是 "10"）
        if(is_good(n,n)){
            k2=n;
        }
    }
    else if(k2==-1 &&k1!=-1&&n>3){ //特殊情况：k = n-1 时可能成立（如 n=5, k=4 → "11"）
        if(is_good(n,n-1)&&n-1!=k1){
            k2=n-1;
        }
    }
    if(k1==-1||k2==-1){
        printf("NO");
        return 0;
    }
    else{
        printf("YES\n");
        printf("%lld %lld",k1,k2);
    }
    return 0;
}

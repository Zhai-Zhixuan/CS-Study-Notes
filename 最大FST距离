#include <stdio.h>
#include <stdlib.h>
//绝对值的和 |a| + |b| 有一个重要的数学性质：
//对于任意实数 a,b，等式|a| + |b| = max{ |a+b|, |a-b| }恒成立。
int cmp(const void*a,const void*b){
    long long diff= *(long long*)a-*(long long*)b;
    if(diff>0) return 1;
    if(diff<0) return -1;
    return 0;
}
int main() {
    int n;
    scanf("%d",&n);
    long long a[100005];
    for(int i=1;i<=n;i++){
        scanf("%lld",&a[i]);
    }
    long long max=0;
    long long u[100005];
    long long v[100005];
    //xi=i**2,yi=ai**2
    //dist(i,j)=|xi-xj|+|yi-yj|=max{|(xi+yi)-(xj+yj),|(xi-yi)-(xj-yj)}
    //Uk=xk+yk=k**2+ak**2,Vk=xk-yk=k**2-ak**2
    //求最大fst距离->max{|Ui-Uj|,|Vi-Vj|}->max{max(U)-min(U),max(V)-min(V)}
    for(int i=1;i<=n;i++){
        u[i-1]=(long long)i*i+a[i]*a[i];
        v[i-1]=(long long)i*i-a[i]*a[i];
    }
    qsort(u,n,sizeof(long long),cmp);
    qsort(v,n,sizeof(long long),cmp);
    long long u_m=u[n-1]-u[0];
    long long v_m=v[n-1]-v[0];
    max=u_m>v_m?u_m:v_m;
    printf("%lld",max);
    return 0;
}

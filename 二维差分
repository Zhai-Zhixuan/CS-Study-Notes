#include <stdio.h>

int main() {
    int n,m,q;
    scanf("%d%d%d",&n,&m,&q);
    long long b[1005][1005]={0};
    long long sum[1005][1005]={0};
    for(int i=1;i<=n;i++){
        for(int j=1;j<=m;j++){
            scanf("%lld",&b[i][j]);
        }
    }
    while(q--){
        int x1,x2,y1,y2;
        long long k;
        scanf("%d %d %d %d %lld",&x1,&y1,&x2,&y2,&k);
        sum[x1][y1]+=k;
        sum[x1][y2+1]-=k;
        sum[x2+1][y1]-=k;
        sum[x2+1][y2+1]+=k;
    }
    for(int i=1;i<=n;i++){
        for(int j=1;j<=m;j++){
            sum[i][j]+=sum[i][j-1]+sum[i-1][j]-sum[i-1][j-1];
            printf("%lld ",sum[i][j]+b[i][j]);
        }
        printf("\n");
    }
    return 0;
}

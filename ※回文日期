#include <stdio.h>
//YYYYMMDD,01<=MM<=12,01<=DD<=31
//01,02,03,10,11,12,13,20,21,22,30,31,32,40,41,42,...90,91,92
//01,10,11,20,21,30,31,40,41,50,51,...90,91
//构造年判断回文日期是否合理，但有大小月和平闰年
//构造日期判断回文年是否合理，√
int main() {
    int a,b;
    scanf("%d",&a);
    scanf("%d",&b);
    int date[13]={0,31,29,31,30,31,30,31,31,30,31,30,31};
    int ans=0;
    for(int i=1;i<=12;i++){
        for(int j=1;j<=date[i];j++){
            int ry=(j%10)*1e7+(j/10)*1e6+(i%10)*1e5+(i/10)*1e4+i*100+j;
            if(ry>=a&&ry<=b){
                ans++;
            }
        }
    }
    printf("%d",ans);
    return 0;
}

#include <stdio.h>
#include <string.h>
#include <ctype.h>
int f1(char *s,int i,int p2){
    for(char j=s[i-1]+1;j<s[i+1];j++){
        for(int k=0;k<p2;k++){
            printf("%c",j);
        }
    } 
    return 0;
}
int f2(char *s,int i,int p2){
    for(char j=s[i+1]-1;j>s[i-1];j--){
        for(int k=0;k<p2;k++){
            printf("%c",j);
        }
    }
    return 0;
}
int f3(char *s,int i,int p2){
    for(char j=s[i-1]+1;j<s[i+1];j++){
        for(int k=0;k<p2;k++){
            if(s[i-1]>='0'&&s[i-1]<='9'){
                printf("%c",j);
            }
            else{
                printf("%c",j-32);
            }
        }
    } 
    return 0;
}
int f4(char *s,int i,int p2){
    for(char j=s[i+1]-1;j>s[i-1];j--){
        for(int k=0;k<p2;k++){
            if(s[i-1]>='0'&&s[i-1]<='9'){
                printf("%c",j);
            }
            else{
                printf("%c",j-32);
            }
        }
    }
    return 0;
}
int main() {
    int p1,p2,p3;
    scanf("%d %d %d",&p1,&p2,&p3);
    char s[105];
    scanf("%s",s);
    int len=strlen(s);
    for(int i=0;i<len;i++){
        if(s[i]=='-'&&i>0&&i<len-1){
            char left=s[i-1];
            char right=s[i+1];
            int type=0;//判断两侧数据类型
            if(isdigit(left)&&isdigit(right)){
                type=1;
            }
            else if(islower(left)&&islower(right)){
                type=1;
            }
            if(type&&s[i+1]-s[i-1]>1){
                if(p1==1){
                    if(p3==1){
                        f1(s,i,p2);
                    }
                    else{
                        f2(s,i,p2);
                    }
                }
                else if(p1==2){
                    if(p3==1){
                        f3(s,i,p2);
                    }
                    else{
                        f4(s,i,p2);
                    }
                }
                else {
                    for(int j=0;j<p2*(s[i+1]-s[i-1]-1);j++){
                        printf("*");
                    }
                }
            }
            else if(type&&s[i+1]-s[i-1]==1){
                continue;
            }
            else{
                printf("%c",s[i]);
            }
        }
        else{
            printf("%c",s[i]);
        }
    }
    return 0;
}

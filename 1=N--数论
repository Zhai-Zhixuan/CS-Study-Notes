#include <stdio.h>
//a,b>=2时，a+b<=a*b恒成立，即求可以分解成最小的质数之和
//唯一分解定理：任何一个大于1的整数，都可以唯一地分解成有限个质数的乘积
int main() {
    int n;
    scanf("%d",&n);
    int cost=0;
    for(int i=2;i*i<=n;i++){
        while(n%i==0){
            cost+=i;
            n/=i;
        }
    }
    if(n>1){
        cost+=n;
    }
    printf("%d",cost);
    return 0;
}

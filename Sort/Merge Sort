#include <iostream>
#include <vector>
using namespace std;
const int MAXN = 501;
vector<int>arr(MAXN);
vector<int>help(MAXN);
int n;

void sort1(int l, int r);
void sort2();
void merge(int l, int m, int r);
int main() {
    cin >> n;
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }
    //sort1(0, n - 1);
    sort2();
    for (int i = 0; i < n; i++) {
        cout << arr[i] << " ";
    }
}

void sort1(int l, int r) { //递归
    if (l == r) {
        return;
    }
    int m = (l + r) / 2;
    sort1(l, m);
    sort1(m + 1, r);
    merge(l, m, r);
}

void sort2() { //非递归
    for (int l, m, r, step = 1; step < n; step <<= 1) {
        l = 0;
        while (l < n) {
            m = l + step - 1;
            if (m + 1 >= n) {
                break;
            }
            r = min(l + (step << 1) - 1, n - 1);
            merge(l, m, r);
            l = r + 1;
        }
    }
}

void merge(int l, int m, int r) {
    int a, i, b;
    a = i  = l, b = m + 1;
    while (a <= m && b <= r) {
        help[i++] = arr[a] < arr[b] ? arr[a++] : arr[b++];
    }
    while (a <= m) {
        help[i++] = arr[a++];
    }
    while (b <= r) {
        help[i++] = arr[b++];
    }
    for ( i = l; i <= r; i++) {
        arr[i] = help[i];
    }
}

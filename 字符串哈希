#include<stdio.h>
#include<stdlib.h>
#include<string.h>
#define MAXN 10001
#define BASE 499
long long nums[MAXN];
int n;
int v(char c){    
if(c>='0'&&c<='9'){        
return c-'0'+1;    
}    
else if(c>='a'&&c<='z'){        
return c-'0'+11;    
}    
else if(c>='A'&&c<='Z'){        
return c-'0'+37;    
}
}
long long value(char* s){//字符串哈希    
int len=strlen(s);    
long long ans=v(s[0]);    
for(int i=1;i<len;i++){        
ans=ans*BASE+v(s[i]);    
}    
return ans;
}
int cmp(const void* a,const void* b){    
long long la=*(long long*)a;    
long long lb=*(long long*)b;    
//第一步：(long long*)a    
//把通用指针 a 强制转换为 long long* 类型    
//告诉编译器："我要把 a 当作指向 long long 的指针来用"    
//第二步：*(long long*)a    
//* 是解引用操作符，获取指针指向的值    
//相当于："取出这个 long long 指针指向的值"    
//第三步：赋值给 long long la    
//把取出的值赋给变量 la    
if(la>lb) return 1;    
if(la<lb) return -1;    
return 0;
}
int cnt(){    
qsort(nums,n,sizeof(long long),cmp);    
// 参数：数组起始地址，元素个数，每个元素大小，比较函数    
int ans=1;    
for(int i=1;i<n;i++){        
if(nums[i]!=nums[i-1]){            
ans++;        
}    
}    
return ans;
}
int main(){    
scanf("%d",&n);    
getchar();    
char buffer[10000]; //创建缓冲区    
for(int i=0;i<n;i++){        
fgets(buffer,sizeof(buffer),stdin); //读取一行        
//buffer：读到的数据存放在哪里        
//sizeof(buffer)：最多读多少个字符（包括结尾的 \0）        
//stdin：从哪里读（标准输入，即键盘）        
size_t len=strlen(buffer);        
if(len>0&&buffer[len-1]=='\n'){            
buffer[len-1]='\0';//检查并移除换行符        
}        
nums[i]=value(buffer);    
}    
printf("%d\n",cnt());    
return 0;
}

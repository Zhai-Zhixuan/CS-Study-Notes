#include <stdio.h>
//植树节即将来临，学校决定组织志愿者为一排编号从 0开始、向右无限延伸的树苗浇水。
//共有 𝑛名志愿者，第 𝑖名志愿者选择了闭区间 [𝑎i,𝑏𝑖]，并为区间内的每一棵树苗各浇一次水
//所有志愿者完成任务后，某些树苗可能被多名志愿者重复浇水，而另一些树苗一次也没有被浇水。
//请你计算被浇水次数最多的树苗最终被浇了多少次。
int main() {
    int n;
    scanf("%d",&n);
    int water[1000005]={0};
    long long max=-1;
    while(n--){
        long long a,b;
        scanf("%lld %lld",&a,&b);
        water[a]++;
        water[b+1]--;
    }
    for(int i=0;i<1000005;i++){
            water[i]+=water[i-1];
            if(water[i]>max){
                max=water[i];
            }
        }
        printf("%lld\n",max);
    return 0;
}

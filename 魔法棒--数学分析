//初始拥有一根魔法棒，它可以进行任意次（也可以不进行）以下操作。
//选择一根魔法棒，将其分裂为任意一个正平方数数量的魔法棒；例如，现在有 1 根魔法棒，选择一个平方数 9之后变成了 9 根魔法棒。
//能否通过这样的分裂魔法获得恰好 x 根魔法棒。
#include <stdio.h>

int main() {
    int t;
    scanf("%d",&t);
    while(t--){
        long long x;
        scanf("%lld",&x);
        if(x==2||x==3||x==5||x==6||x==8||x==11||x==14){
            printf("No\n");
        }
        else printf("Yes\n");
    }
    return 0;
}

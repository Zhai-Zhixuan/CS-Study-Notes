#include <iostream>
using namespace std;

int main() {
    int t;
    cin >> t;
    while(t--){
        long long a,b,p;
        long long ans = 1;
        cin >> a >> b >> p;
        while(b>0){
            if(b&1){
                ans = (ans*a)%p;
            }
            a = (a*a)%p;
            b >>= 1;
        }
        printf("%lld\n",ans%p);
    }
}

#include <iostream>
#define MOD 1000000007
using namespace std;
long long power(long long a,long long b,long long mod){
    long long ans = 1;
    for(;b>0;b>>=1){
        if(b&1){
            ans = (ans*a)%mod;
        }
        a = (a*a)%mod;
    }
    return ans%mod;
}
int main() {
    int t;
    cin >> t;
    while(t--){
        long long a,b,c;
        cin >> a >> b >> c;
        long long ans1 = power(b,c,MOD-1);
        long long ans = power(a,ans1,MOD);
        //底数a: a^b mod MOD，底数直接对 MOD 取模
        //指数b^c:费马小定理：a^(MOD-1) ≡ 1，所以指数循环节是 MOD-1
        printf("%lld\n",ans%MOD);
    }
}
